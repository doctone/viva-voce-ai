{
  "name": "viva-voce-ai",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=web",
    "deploy:web": "pnpm --filter web deploy",
    "cf-typegen:web": "pnpm --filter web cf-typegen",
    "preview": "turbo run preview --filter=web",
    "start": "turbo run start --filter=web"
  },
  "devDependencies": {
    "turbo": "^2.5.3"
  }
}
