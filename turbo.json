{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "apps/web/.env",
    "packages/database/supabase/config.toml",
    "packages/database/supabase/seed.sql"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "db:start": {
      "cache": false
    },
    "db:stop": {
      "cache": false
    },
    "db:reset": {
      "cache": false
    }
  }
}
